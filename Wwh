
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "FRIN TEAM | OVERDRIVE",
   LoadingTitle = "Setting Frequency to 0.1s...",
   LoadingSubtitle = "by Frin Team",
   ConfigurationSaving = { Enabled = false }
})

--// [ VARIABLES ]
local UserText = "ezz"
local AutoLoop = false
local TickRate = 0.1 -- Your requested speed

--// [ CORE LOGIC ]
local function fireLalolLogic(payload)
    for _, remote in pairs(game:GetDescendants()) do
        if remote:IsA("RemoteFunction") then
            local fullName = remote:GetFullName()
            
            -- LALOL Safety Filters
            if not string.find(fullName, "RobloxReplicatedStorage") and 
               not string.find(fullName, "DefaultChatSystemChatEvents") then
                
                task.spawn(function()
                    pcall(function()
                        -- Rapid Invoke
                        remote:InvokeServer(payload)
                    end)
                end)
            end
        end
    end
end

-- Ultra-Fast Loop Thread
task.spawn(function()
    while true do
        if AutoLoop and UserText ~= "" then
            fireLalolLogic(UserText)
        end
        task.wait(TickRate) -- Fixed at 0.1s
    end
end)

--// [ UI SETUP ]
local MainTab = Window:CreateTab("Overdrive", 4483362458)

MainTab:CreateSection("Payload Configuration")

MainTab:CreateInput({
   Name = "Target Message",
   PlaceholderText = "Input overwrite text...",
   RemoveTextAfterFocusLost = false,
   Callback = function(val)
       UserText = val
   end,
})

MainTab:CreateSection("Loop Settings")

MainTab:CreateToggle({
   Name = "Rapid Auto-Restore (0.1s)",
   CurrentValue = false,
   Flag = "RapidToggle",
   Callback = function(Value)
       AutoLoop = Value
       if Value then
           Rayfield:Notify({
               Title = "Overdrive Active",
               Content = "Overwriting every 0.1 seconds. Warning: High Traffic.",
               Duration = 3
           })
       end
   end,
})

MainTab:CreateSection("Status")
MainTab:CreateLabel("Current Rate: 0.1s")

Rayfield:Notify({
   Title = "System Ready",
   Content = "Speed set to 0.1s. Use toggle to start.",
   Duration = 5
})
